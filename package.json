{
  "name": "marketplace-auditor",
  "version": "0.5.0",
  "description": "Atlassian Marketplace transaction and license auditor",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "dist/server/src/server/index.js",
  "imports": {
    "#common/*": {
      "development": "./src/common/*",
      "default": "./dist/server/src/common/*"
    },
    "#server/*": {
      "development": "./src/server/*",
      "default": "./dist/server/src/server/*"
    },
    "#client/*": "./src/client/*"
  },
  "scripts": {
    "build": "npm audit --audit-level high && npm run build:server && npm run build:client",
    "build:server": "tsc -p src/server/tsconfig.json",
    "build:client": "vite build",
    "build:client:dev": "vite build --mode development",
    "build:client:prod": "vite build --mode production",
    "start": "NODE_ENV=production node dist/server/src/server/index.js",
    "start:dev": "NODE_ENV=development NODE_OPTIONS='--conditions=development' tsx --tsconfig src/server/tsconfig.json src/server/index.ts",
    "test": "jest",
    "generate-types": "openapi-typescript https://dac-static.atlassian.com/platform/marketplace/swagger.v3.json?_v=1.2006.608 --output src/common/types/marketplace-api.ts",
    "generate-v3-types": "openapi-typescript https://dac-static.atlassian.com/platform/marketplace/swagger.marketplace.v3.json?_v=1.2006.666 --output src/common/types/marketplace-v3-api.ts",
    "generate-commerce-types": "openapi-typescript https://dac-static.atlassian.com/platform/commerce/swagger.v3.json?_v=1.0.54 --output src/common/types/commerce-api.ts",
    "jobs": "NODE_ENV=development tsx --tsconfig src/server/tsconfig.json src/server/cli/runJobs.ts",
    "add-addon": "tsx --tsconfig src/server/tsconfig.json src/server/cli/addAddon.ts",
    "add-ignored-field": "tsx --tsconfig src/server/tsconfig.json src/server/cli/addIgnoredField.ts",
    "backfill-version-numbers": "tsx --tsconfig src/server/tsconfig.json src/server/cli/backfillVersionNumbers.ts",
    "export-pricing-template": "tsx --tsconfig src/server/tsconfig.json src/server/cli/exportPricingTemplate.ts",
    "import-pricing": "tsx --tsconfig src/server/tsconfig.json src/server/cli/importPricing.ts",
    "add-reseller": "tsx --tsconfig src/server/tsconfig.json src/server/cli/addReseller.ts",
    "add-transaction-adjustment": "tsx --tsconfig src/server/tsconfig.json src/server/cli/addTransactionAdjustment.ts",
    "preview:client": "vite preview",
    "preview:client:prod": "vite preview --mode production",
    "analyze:client": "vite build --mode analyze",
    "clean:client": "rimraf dist/client"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@faker-js/faker": "^9.8.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/x-date-pickers": "^8.5.1",
    "@mui/x-tree-view": "^8.5.1",
    "@slack/web-api": "^7.9.2",
    "axios": "^1.6.7",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dayjs": "^1.11.20",
    "diff": "^5.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "inversify": "^7.5.1",
    "node-cron": "^4.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "reflect-metadata": "^0.2.2",
    "stream-json": "^1.7.6",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0",
    "validator": "^13.15.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/diff": "^5.0.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/stream-json": "^1.7.8",
    "@types/validator": "^13.15.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.14"
  }
}
