{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "../../dist/server",
    "rootDir": "../..",
    "baseUrl": "../..",
    "paths": {
      "#common/*": ["./src/common/*"],
      "#server/*": ["./src/server/*"],
      "#client/*": ["./src/client/*"]
    }
  },
  "include": [
    "./**/*",
    "../common/**/*",
    "./types/**/*"
  ],
  "exclude": [
    "node_modules",
    "cli",
    "**/*.test.ts",
    "**/__tests__/**",
    "../common/**/__tests__/**",
    "dist"
  ]
}
